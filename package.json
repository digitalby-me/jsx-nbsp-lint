  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "jsx",
    "react",
    "typography",
    "nbsp",
    "non-breaking-space"
  ],
  "license": "MIT",
  "author": "digitalby <yury@digitalby.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digitalby-me/jsx-nbsp-lint.git"
  },
  "main": "lib/index.js",
  "bin": {
    "jsx-nbsp": "bin/jsx-nbsp.js"
  },
  "files": [
    "lib",
    "bin",
    "eslint.bundled.config.mjs"
  ],
  "scripts": {
    "test": "node --test"
  },
  "peerDependencies": {
    "eslint": ">=8.40.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0"
  }
}
